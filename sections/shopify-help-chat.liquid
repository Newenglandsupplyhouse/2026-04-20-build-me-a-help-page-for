{% liquid
  assign section_id = 'shopify-help-chat-' | append: section.id
  assign chatbase_proxy_url = section.settings.chatbase_proxy_url | default: 'https://shopify-help-chat.onrender.com/chatbase-help'
  assign chatbase_url = section.settings.chatbase_url | default: 'https://www.chatbase.co/iQxwux6_Bjma9xxVgm8Nb/help'
  assign iframe_url = chatbase_proxy_url

  if iframe_url == blank
    assign iframe_url = chatbase_url
  endif
%}

<section class="shopify-chatbase-help" id="{{ section_id }}">
  {% if iframe_url != blank %}
    <button
      class="shopify-chatbase-help__reset"
      type="button"
      aria-label="Start over"
      title="Start over"
    >
      <span class="shopify-chatbase-help__reset-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M20 11a8 8 0 1 0-2.34 5.66" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M20 4v7h-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
      <span class="shopify-chatbase-help__reset-text">Start over</span>
    </button>
    <iframe
      class="shopify-chatbase-help__frame"
      src="{{ iframe_url | escape }}"
      title="Help page"
      loading="lazy"
      allow="clipboard-write; microphone"
    ></iframe>
  {% else %}
    <div class="shopify-chatbase-help__empty">
      <h2 class="shopify-chatbase-help__empty-title">Add your Chatbase help page URL</h2>
      <p class="shopify-chatbase-help__empty-text">Open this section in the theme editor and paste your Chatbase help page link.</p>
    </div>
  {% endif %}
</section>

<style>
  body.shopify-chatbase-help-page footer,
  body.shopify-chatbase-help-page .shopify-section-group-footer-group,
  body.shopify-chatbase-help-page [id*="shopify-section"][id*="footer"] {
    display: none !important;
  }

  #{{ section_id }} {
    --shopify-help-header-offset: 164px;
    --shopify-help-viewport-height: 100dvh;
    --shopify-help-safe-bottom: env(safe-area-inset-bottom, 0px);
    --shopify-help-mobile-frame-shift: 0px;
    box-sizing: border-box;
    height: calc(var(--shopify-help-viewport-height) - var(--shopify-help-header-offset));
    min-height: calc(var(--shopify-help-viewport-height) - var(--shopify-help-header-offset));
    position: relative;
    background: #08080b;
    overflow: hidden;
  }

  @media screen and (max-width: 749px) {
    #{{ section_id }} {
      --shopify-help-header-offset: 0px;
      position: fixed;
      left: 0;
      right: 0;
      top: var(--shopify-help-header-offset);
      bottom: 0;
      z-index: 2;
    }
  }

  #{{ section_id }} .shopify-chatbase-help__frame {
    display: block;
    width: 100%;
    height: calc(var(--shopify-help-viewport-height) - var(--shopify-help-header-offset));
    min-height: calc(var(--shopify-help-viewport-height) - var(--shopify-help-header-offset));
    border: 0;
    background: #08080b;
    transform: translateY(var(--shopify-help-mobile-frame-shift));
    transform-origin: top center;
    touch-action: pan-y;
  }

  #{{ section_id }} .shopify-chatbase-help__empty {
    height: calc(var(--shopify-help-viewport-height) - var(--shopify-help-header-offset));
    min-height: calc(var(--shopify-help-viewport-height) - var(--shopify-help-header-offset));
    display: grid;
    place-items: center;
    padding: 24px;
    text-align: center;
    color: #f5f5f7;
    background: #08080b;
  }

  #{{ section_id }} .shopify-chatbase-help__empty-title {
    margin: 0 0 10px;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  #{{ section_id }} .shopify-chatbase-help__empty-text {
    margin: 0;
    max-width: 560px;
    color: #a2a3aa;
    font-size: 1rem;
    line-height: 1.6;
  }

  #{{ section_id }} .shopify-chatbase-help__reset {
    position: absolute;
    right: max(18px, calc(50% - 340px));
    bottom: max(calc(176px + var(--shopify-help-safe-bottom)), 24px);
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 40px;
    padding: 0 14px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    background: rgba(17, 17, 22, 0.92);
    color: #f5f5f7;
    font-size: 13px;
    font-weight: 600;
    line-height: 1;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }

  #{{ section_id }} .shopify-chatbase-help__reset:hover {
    background: rgba(31, 31, 38, 0.98);
    border-color: rgba(255, 255, 255, 0.22);
    transform: translateY(-1px);
  }

  #{{ section_id }} .shopify-chatbase-help__reset:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.45);
    outline-offset: 2px;
  }

  #{{ section_id }} .shopify-chatbase-help__reset-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  #{{ section_id }} .shopify-chatbase-help__reset-icon svg {
    width: 15px;
    height: 15px;
  }

  @media screen and (max-width: 749px) {
    #{{ section_id }} .shopify-chatbase-help__reset {
      right: max(12px, env(safe-area-inset-right, 0px));
      bottom: auto;
      top: 8px;
      min-height: 36px;
      padding: 0 12px;
      font-size: 12px;
    }
  }
</style>

<script>
  (() => {
    const root = document.getElementById({{ section_id | json }});
    if (!root) {
      return;
    }

    const pageRoot = document.documentElement;
    const body = document.body;

    if (pageRoot) {
      pageRoot.style.overflow = "hidden";
      pageRoot.style.height = "100%";
    }

    if (body) {
      body.classList.add("shopify-chatbase-help-page");
      body.style.overflow = "hidden";
      body.style.height = "100%";
      body.style.minHeight = "100%";
    }

    const frame = root.querySelector(".shopify-chatbase-help__frame");
    const resetButton = root.querySelector(".shopify-chatbase-help__reset");
    const isMobileViewport = () => window.innerWidth <= 749;
    const isPortraitMobileViewport = () => isMobileViewport() && window.innerHeight >= window.innerWidth;
    const frameOrigin = frame ? new URL(frame.getAttribute("src"), window.location.href).origin : "";

    const setMobileFrameShift = (shift) => {
      const nextShift = (isMobileViewport() && !isPortraitMobileViewport()) ? -Math.max(0, Math.round(Number(shift) || 0)) : 0;
      root.style.setProperty("--shopify-help-mobile-frame-shift", `${nextShift}px`);
    };

    const updateViewportHeight = () => {
      const viewportHeight = isMobileViewport()
        ? window.innerHeight
        : (window.visualViewport?.height || window.innerHeight);
      root.style.setProperty("--shopify-help-viewport-height", `${Math.round(viewportHeight)}px`);
    };

    const updateHeaderOffset = () => {
      const selectors = [
        'header',
        '[role="banner"]',
        '.section-header',
        '.header-wrapper',
        '.shopify-section-group-header-group',
        '[id*="shopify-section"][id*="header"]',
        '.announcement-bar',
        '.utility-bar',
        '.top-bar'
      ];

      const candidates = selectors
        .flatMap((selector) => [...document.querySelectorAll(selector)])
        .filter((element, index, array) => array.indexOf(element) === index)
        .filter((element) => !root.contains(element))
        .filter((element) => {
          const rect = element.getBoundingClientRect();
          const style = window.getComputedStyle(element);

          if (style.display === "none" || style.visibility === "hidden") {
            return false;
          }

          if (rect.height <= 0 || rect.height > 320) {
            return false;
          }

          return rect.bottom > 0 && rect.top < window.innerHeight * 0.5;
        });

      const measuredOffset = candidates.reduce((maxBottom, element) => {
        const rect = element.getBoundingClientRect();
        return Math.max(maxBottom, Math.ceil(rect.bottom));
      }, 0);

      const fallbackOffset = window.innerWidth <= 749 ? 0 : 164;
      const headerOffset = window.innerWidth <= 749
        ? measuredOffset
        : Math.max(measuredOffset, fallbackOffset);

      root.style.setProperty("--shopify-help-header-offset", `${headerOffset}px`);
    };

    const disableMobileTimerInterception = () => {
      if (!isMobileViewport()) {
        return;
      }

      const timerCandidates = [...document.querySelectorAll("body *")].filter((element) => {
        const tagName = (element.tagName || "").toLowerCase();
        const className = typeof element.className === "string" ? element.className.toLowerCase() : "";
        const id = (element.id || "").toLowerCase();
        const text = (element.textContent || "").toLowerCase();

        return (
          tagName.startsWith("countdown-timer-") ||
          className.includes("countdown") ||
          className.includes("timer") ||
          id.includes("countdown") ||
          id.includes("timer") ||
          text.includes("same day shipping") ||
          text.includes("order by 3pm")
        );
      });

      timerCandidates.forEach((element) => {
        try {
          element.style.pointerEvents = "none";
        } catch {}
      });
    };

    window.addEventListener("message", (event) => {
      if (!frame || event.origin !== frameOrigin || !event.data) {
        return;
      }

      if (event.data.type !== "nesh-chatbase-mobile-offset") {
        return;
      }

      if (!isMobileViewport()) {
        setMobileFrameShift(0);
        return;
      }

      setMobileFrameShift(event.data.active ? event.data.shift : 0);
    });

    if (frame && resetButton) {
      const initialSrc = frame.getAttribute("src");
      resetButton.addEventListener("click", () => {
        setMobileFrameShift(0);
        const baseUrl = new URL(initialSrc, window.location.href);
        const freshUrl = new URL(baseUrl.toString());
        freshUrl.searchParams.set("reset", String(Date.now()));
        const resetUrl = new URL("/chatbase-help/reset", baseUrl.origin);
        resetUrl.searchParams.set("next", freshUrl.toString());
        frame.setAttribute("src", "about:blank");
        window.setTimeout(() => {
          frame.setAttribute("src", resetUrl.toString());
        }, 20);
      });
    }

    updateViewportHeight();
    updateHeaderOffset();
    disableMobileTimerInterception();
    if (!isMobileViewport()) {
      window.visualViewport?.addEventListener("resize", updateViewportHeight);
      window.visualViewport?.addEventListener("scroll", updateViewportHeight);
    }
    window.addEventListener("orientationchange", updateViewportHeight);
    window.addEventListener("resize", updateViewportHeight);
    window.addEventListener("resize", () => setMobileFrameShift(0));
    window.addEventListener("resize", updateHeaderOffset);
    window.addEventListener("resize", disableMobileTimerInterception);
    window.addEventListener("load", updateHeaderOffset);
    window.addEventListener("load", updateViewportHeight);
    window.addEventListener("load", disableMobileTimerInterception);
    setTimeout(updateHeaderOffset, 250);
    setTimeout(updateHeaderOffset, 1000);
    setTimeout(updateViewportHeight, 250);
    setTimeout(disableMobileTimerInterception, 250);
    setTimeout(disableMobileTimerInterception, 1000);
  })();
</script>

{% schema %}
{
  "name": "Shopify Help Chat",
  "settings": [
    {
      "type": "url",
      "id": "chatbase_proxy_url",
      "label": "Chatbase proxy URL",
      "info": "Recommended. Paste your proxied help page URL, for example https://shopify-help-chat.onrender.com/chatbase-help"
    },
    {
      "type": "url",
      "id": "chatbase_url",
      "label": "Direct Chatbase help page URL",
      "info": "Optional fallback. Paste your direct Chatbase help page URL if you are not using the proxy."
    }
  ],
  "presets": [
    {
      "name": "Shopify Help Chat"
    }
  ]
}
{% endschema %}
