{% liquid
  assign section_id = 'shopify-help-chat-' | append: section.id
  assign heading = section.settings.heading | default: 'How can I help you today?'
  assign intro_message = section.settings.intro_message | default: 'Ask about parts, model numbers, compatibility, shipping, or availability.'
  assign placeholder = section.settings.placeholder | default: 'Ask me anything...'
  assign api_url = section.settings.api_url
%}

<section class="shopify-help-chat" id="{{ section_id }}">
  <div class="shopify-help-chat__inner">
    <div class="shopify-help-chat__hero">
      <h1 class="shopify-help-chat__heading">{{ heading | escape }}</h1>
      <p class="shopify-help-chat__subheading">{{ intro_message | escape }}</p>
    </div>

    <div class="shopify-help-chat__composer-wrap">
      <div class="shopify-help-chat__glow" aria-hidden="true"></div>

      <div class="shopify-help-chat__shell">
        <div class="shopify-help-chat__messages" data-help-messages hidden>
          <article class="shopify-help-chat__message shopify-help-chat__message--assistant">
            <p class="shopify-help-chat__message-text">{{ intro_message | escape }}</p>
          </article>
        </div>

        <form class="shopify-help-chat__form" data-help-form>
          <label class="shopify-help-chat__sr-only" for="{{ section_id }}-input">Ask a question</label>
          <textarea
            class="shopify-help-chat__input"
            data-help-input
            id="{{ section_id }}-input"
            rows="3"
            aria-label="Ask a question"
            placeholder="{{ placeholder | escape }}"
          ></textarea>

          <div class="shopify-help-chat__actions">
            <span class="shopify-help-chat__hint">Press Enter to send</span>
            <button class="shopify-help-chat__send" type="submit" aria-label="Send question">
              <span class="shopify-help-chat__send-icon">||</span>
            </button>
          </div>
        </form>
      </div>
    </div>

    <p class="shopify-help-chat__status" data-help-status></p>
  </div>
</section>

<style>
  #{{ section_id }} {
    --help-bg: #08080b;
    --help-shell: #1a1a1f;
    --help-shell-border: rgba(255, 255, 255, 0.08);
    --help-text: #f5f5f7;
    --help-muted: #9b9ca3;
    --help-placeholder: #b6b8c3;
    --help-button: #ffffff;
    --help-button-text: #121216;
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    background: var(--help-bg);
    color: var(--help-text);
    padding: 40px 16px 80px;
  }

  #{{ section_id }} * {
    box-sizing: border-box;
  }

  #{{ section_id }} .shopify-help-chat__inner {
    width: min(980px, 100%);
    margin: 0 auto;
    min-height: calc(100vh - 120px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  #{{ section_id }} .shopify-help-chat__hero {
    text-align: center;
    margin-bottom: 28px;
  }

  #{{ section_id }} .shopify-help-chat__heading {
    margin: 0;
    font-size: clamp(2.5rem, 5vw, 4.2rem);
    line-height: 1.02;
    letter-spacing: -0.05em;
    font-weight: 700;
    text-wrap: balance;
  }

  #{{ section_id }} .shopify-help-chat__subheading {
    margin: 14px 0 0;
    color: var(--help-muted);
    font-size: 1rem;
    line-height: 1.6;
  }

  #{{ section_id }} .shopify-help-chat__composer-wrap {
    position: relative;
    width: min(940px, 100%);
  }

  #{{ section_id }} .shopify-help-chat__glow {
    position: absolute;
    left: 6%;
    right: 6%;
    bottom: -18px;
    height: 56px;
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      rgba(132, 70, 255, 0.32) 0%,
      rgba(223, 82, 160, 0.30) 24%,
      rgba(255, 143, 84, 0.28) 46%,
      rgba(163, 217, 74, 0.28) 68%,
      rgba(67, 190, 255, 0.30) 100%
    );
    filter: blur(28px);
    opacity: 0.95;
    pointer-events: none;
  }

  #{{ section_id }} .shopify-help-chat__shell {
    position: relative;
    border: 1px solid var(--help-shell-border);
    border-radius: 28px;
    background: var(--help-shell);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
    padding: 18px 18px 16px;
  }

  #{{ section_id }} .shopify-help-chat__messages {
    max-height: 260px;
    overflow-y: auto;
    margin-bottom: 12px;
    padding: 6px 4px;
  }

  #{{ section_id }} .shopify-help-chat__message {
    margin: 0 0 10px;
  }

  #{{ section_id }} .shopify-help-chat__message:last-child {
    margin-bottom: 0;
  }

  #{{ section_id }} .shopify-help-chat__message-text {
    margin: 0;
    color: var(--help-text);
    white-space: pre-wrap;
    word-break: break-word;
    line-height: 1.65;
  }

  #{{ section_id }} .shopify-help-chat__message-text a {
    color: #d9defd;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  #{{ section_id }} .shopify-help-chat__documents {
    margin-top: 14px;
    display: grid;
    gap: 10px;
  }

  #{{ section_id }} .shopify-help-chat__document {
    display: block;
    padding: 12px 14px;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    color: var(--help-text);
    text-decoration: none;
  }

  #{{ section_id }} .shopify-help-chat__document:hover,
  #{{ section_id }} .shopify-help-chat__document:focus-visible {
    border-color: rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.05);
    outline: none;
  }

  #{{ section_id }} .shopify-help-chat__document-title {
    display: block;
    font-size: 0.96rem;
    font-weight: 700;
    line-height: 1.4;
  }

  #{{ section_id }} .shopify-help-chat__document-meta {
    display: block;
    margin-top: 4px;
    color: var(--help-muted);
    font-size: 0.84rem;
  }

  #{{ section_id }} .shopify-help-chat__form {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  #{{ section_id }} .shopify-help-chat__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  #{{ section_id }} .shopify-help-chat__input {
    width: 100%;
    min-height: 116px;
    resize: none;
    border: 0;
    outline: none;
    background: transparent;
    color: var(--help-text);
    font: inherit;
    font-size: clamp(1.1rem, 2vw, 1.25rem);
    line-height: 1.5;
    padding: 0 8px;
  }

  #{{ section_id }} .shopify-help-chat__input::placeholder {
    color: var(--help-placeholder);
  }

  #{{ section_id }} .shopify-help-chat__actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  #{{ section_id }} .shopify-help-chat__hint {
    color: var(--help-muted);
    font-size: 0.92rem;
  }

  #{{ section_id }} .shopify-help-chat__send {
    width: 48px;
    height: 48px;
    border: 0;
    border-radius: 16px;
    background: var(--help-button);
    color: var(--help-button-text);
    display: inline-grid;
    place-items: center;
    cursor: pointer;
    transition: transform 140ms ease, opacity 140ms ease;
  }

  #{{ section_id }} .shopify-help-chat__send:hover,
  #{{ section_id }} .shopify-help-chat__send:focus-visible {
    transform: translateY(-1px);
    opacity: 0.96;
    outline: none;
  }

  #{{ section_id }} .shopify-help-chat__send:disabled,
  #{{ section_id }} .shopify-help-chat__input:disabled {
    opacity: 0.62;
    cursor: wait;
  }

  #{{ section_id }} .shopify-help-chat__send-icon {
    display: inline-block;
    transform: rotate(90deg);
    font-weight: 700;
    letter-spacing: -0.1em;
    font-size: 1.05rem;
    line-height: 1;
  }

  #{{ section_id }} .shopify-help-chat__status {
    margin: 18px 0 0;
    min-height: 20px;
    color: var(--help-muted);
    font-size: 0.92rem;
    text-align: center;
  }

  @media (max-width: 640px) {
    #{{ section_id }} {
      padding: 28px 14px 64px;
    }

    #{{ section_id }} .shopify-help-chat__inner {
      min-height: calc(100vh - 92px);
    }

    #{{ section_id }} .shopify-help-chat__hero {
      margin-bottom: 22px;
    }

    #{{ section_id }} .shopify-help-chat__subheading {
      font-size: 0.95rem;
    }

    #{{ section_id }} .shopify-help-chat__shell {
      border-radius: 24px;
      padding: 16px 14px 14px;
    }

    #{{ section_id }} .shopify-help-chat__input {
      min-height: 96px;
      font-size: 1.06rem;
    }

    #{{ section_id }} .shopify-help-chat__hint {
      font-size: 0.86rem;
    }
  }
</style>

<script>
  (() => {
    const root = document.getElementById({{ section_id | json }});
    if (!root || root.dataset.initialized === "true") {
      return;
    }

    root.dataset.initialized = "true";

    const apiUrl = {{ api_url | json }};
    const messagesEl = root.querySelector("[data-help-messages]");
    const formEl = root.querySelector("[data-help-form]");
    const inputEl = root.querySelector("[data-help-input]");
    const statusEl = root.querySelector("[data-help-status]");
    const sendButton = formEl.querySelector(".shopify-help-chat__send");
    const conversation = [];

    function buildMessageFragments(text) {
      const fragment = document.createDocumentFragment();
      const urlPattern = /(https?:\/\/[^\s]+)/g;
      const lines = String(text).split("\n");

      lines.forEach((line, lineIndex) => {
        let lastIndex = 0;
        line.replace(urlPattern, (match, _group, offset) => {
          if (offset > lastIndex) {
            fragment.appendChild(document.createTextNode(line.slice(lastIndex, offset)));
          }

          const link = document.createElement("a");
          link.href = match;
          link.target = "_blank";
          link.rel = "noopener noreferrer";
          link.textContent = match;
          fragment.appendChild(link);
          lastIndex = offset + match.length;
          return match;
        });

        if (lastIndex < line.length) {
          fragment.appendChild(document.createTextNode(line.slice(lastIndex)));
        }

        if (lineIndex < lines.length - 1) {
          fragment.appendChild(document.createElement("br"));
        }
      });

      return fragment;
    }

    function renderDocuments(documents) {
      if (!Array.isArray(documents) || !documents.length) {
        return null;
      }

      const wrapper = document.createElement("div");
      wrapper.className = "shopify-help-chat__documents";

      documents.forEach((documentItem) => {
        const link = document.createElement("a");
        link.className = "shopify-help-chat__document";
        link.href = documentItem.url || "#";
        link.target = "_blank";
        link.rel = "noopener noreferrer";

        const title = document.createElement("span");
        title.className = "shopify-help-chat__document-title";
        title.textContent = documentItem.filename || "Document";

        const meta = document.createElement("span");
        meta.className = "shopify-help-chat__document-meta";
        meta.textContent = documentItem.snippet
          ? documentItem.snippet
          : "Open document";

        link.appendChild(title);
        link.appendChild(meta);
        wrapper.appendChild(link);
      });

      return wrapper;
    }

    function renderMessage(role, text, documents = []) {
      const article = document.createElement("article");
      article.className = "shopify-help-chat__message shopify-help-chat__message--" + role;

      const body = document.createElement("p");
      body.className = "shopify-help-chat__message-text";
      body.appendChild(buildMessageFragments(text));

      article.appendChild(body);
      const documentList = renderDocuments(documents);
      if (documentList) {
        article.appendChild(documentList);
      }
      messagesEl.hidden = false;
      messagesEl.appendChild(article);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function setBusy(isBusy) {
      inputEl.disabled = isBusy;
      sendButton.disabled = isBusy;
    }

    async function sendConversation() {
      statusEl.textContent = "Thinking...";

      const response = await fetch(apiUrl, {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          conversation
        })
      });

      const payload = await response.json();

      if (!response.ok) {
        throw new Error(payload.error || "Something went wrong.");
      }

      return payload;
    }

    async function submitText(text) {
      if (!apiUrl) {
        statusEl.textContent = "Add your backend API URL in the section settings.";
        return;
      }

      conversation.push({ role: "user", content: text });
      renderMessage("user", text);
      inputEl.value = "";
      setBusy(true);

      try {
        const payload = await sendConversation();
        const answer = payload.reply || "I couldn't find an answer yet.";

        conversation.push({ role: "assistant", content: answer });
        renderMessage("assistant", answer, payload.documents || []);
        statusEl.textContent = payload.usedTools || "";
      } catch (error) {
        renderMessage("assistant", error.message);
        statusEl.textContent = "The request did not complete.";
      } finally {
        setBusy(false);
        inputEl.focus();
      }
    }

    formEl.addEventListener("submit", async (event) => {
      event.preventDefault();

      const text = inputEl.value.trim();
      if (!text) {
        return;
      }

      await submitText(text);
    });

    inputEl.addEventListener("keydown", async (event) => {
      if (event.key === "Enter" && !event.shiftKey) {
        event.preventDefault();

        const text = inputEl.value.trim();
        if (!text) {
          return;
        }

        await submitText(text);
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Shopify Help Chat",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How can I help you today?"
    },
    {
      "type": "text",
      "id": "intro_message",
      "label": "Intro message",
      "default": "Ask about parts, model numbers, compatibility, shipping, or availability."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Ask me anything..."
    },
    {
      "type": "url",
      "id": "api_url",
      "label": "Backend API URL",
      "info": "Public HTTPS endpoint for your OpenAI proxy, such as https://your-backend.example.com/api/chat"
    }
  ],
  "presets": [
    {
      "name": "Shopify Help Chat"
    }
  ]
}
{% endschema %}
