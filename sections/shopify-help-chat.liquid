{% liquid
  assign section_id = 'shopify-help-chat-' | append: section.id
  assign chatbase_url = section.settings.chatbase_url | default: 'https://www.chatbase.co/iQxwux6_Bjma9xxVgm8Nb/help'
%}

<section class="shopify-chatbase-help" id="{{ section_id }}">
  {% if chatbase_url != blank %}
    <iframe
      class="shopify-chatbase-help__frame"
      src="{{ chatbase_url | escape }}"
      title="Help page"
      loading="lazy"
      allow="clipboard-write; microphone"
    ></iframe>
  {% else %}
    <div class="shopify-chatbase-help__empty">
      <h2 class="shopify-chatbase-help__empty-title">Add your Chatbase help page URL</h2>
      <p class="shopify-chatbase-help__empty-text">Open this section in the theme editor and paste your Chatbase help page link.</p>
    </div>
  {% endif %}
</section>

<style>
  #{{ section_id }} {
    height: 100dvh;
    min-height: 100dvh;
    background: #08080b;
    padding: 0;
    overflow: hidden;
  }

  #{{ section_id }} .shopify-chatbase-help__frame {
    display: block;
    width: 100%;
    height: 100dvh;
    min-height: 100dvh;
    border: 0;
    background: #08080b;
  }

  #{{ section_id }} .shopify-chatbase-help__empty {
    height: 100dvh;
    min-height: 100dvh;
    display: grid;
    place-items: center;
    padding: 24px;
    text-align: center;
    color: #f5f5f7;
    background: #08080b;
  }

  #{{ section_id }} .shopify-chatbase-help__empty-title {
    margin: 0 0 10px;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  #{{ section_id }} .shopify-chatbase-help__empty-text {
    margin: 0;
    max-width: 560px;
    color: #a2a3aa;
    font-size: 1rem;
    line-height: 1.6;
  }
</style>

<script>
  (() => {
    const root = document.getElementById({{ section_id | json }});
    if (!root) {
      return;
    }

    const pageRoot = document.documentElement;
    const body = document.body;

    if (pageRoot) {
      pageRoot.style.overflow = "hidden";
      pageRoot.style.height = "100%";
    }

    if (body) {
      body.style.overflow = "hidden";
      body.style.height = "100%";
      body.style.minHeight = "100%";
    }
  })();
</script>

{% schema %}
{
  "name": "Shopify Help Chat",
  "settings": [
    {
      "type": "url",
      "id": "chatbase_url",
      "label": "Chatbase help page URL",
      "info": "Paste your Chatbase help page URL, for example https://www.chatbase.co/your-agent-id/help"
    }
  ],
  "presets": [
    {
      "name": "Shopify Help Chat"
    }
  ]
}
{% endschema %}
