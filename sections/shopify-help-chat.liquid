{% liquid
  assign section_id = 'shopify-help-chat-' | append: section.id
  assign heading = section.settings.heading | default: 'What are you shopping for today?'
  assign intro_message = section.settings.intro_message | default: 'Ask about products, sizing, shipping, or recommendations.'
  assign placeholder = section.settings.placeholder | default: 'Type here and press Enter'
  assign api_url = section.settings.api_url
%}

<section class="shopify-help-chat" id="{{ section_id }}">
  <div class="shopify-help-chat__inner">
    <h1 class="shopify-help-chat__heading">{{ heading | escape }}</h1>

    <div class="shopify-help-chat__shell">
      <div class="shopify-help-chat__messages" data-help-messages>
        <p class="shopify-help-chat__message shopify-help-chat__message--assistant">
          <strong>Assistant</strong><br>
          {{ intro_message | escape }}
        </p>
      </div>

      <form class="shopify-help-chat__form" data-help-form>
        <input
          class="shopify-help-chat__input"
          data-help-input
          type="text"
          aria-label="Shopping search"
          autocomplete="off"
          placeholder="{{ placeholder | escape }}"
        >
      </form>
    </div>

    <p class="shopify-help-chat__status" data-help-status></p>
  </div>
</section>

<style>
  #{{ section_id }} {
    --help-page-bg: #ffffff;
    --help-text: #111111;
    --help-muted: #666666;
    --help-border: #dcdcdc;
    --help-surface: #ffffff;
    background: var(--help-page-bg);
    color: var(--help-text);
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 40px 16px;
  }

  #{{ section_id }} * {
    box-sizing: border-box;
  }

  #{{ section_id }} .shopify-help-chat__inner {
    width: min(92vw, 680px);
    text-align: center;
  }

  #{{ section_id }} .shopify-help-chat__heading {
    margin: 0 0 18px;
    font-size: clamp(1.6rem, 2vw, 2.2rem);
    font-weight: 600;
    color: var(--help-text);
  }

  #{{ section_id }} .shopify-help-chat__shell {
    border: 1px solid var(--help-border);
    border-radius: 14px;
    background: var(--help-surface);
    padding: 14px;
    text-align: left;
  }

  #{{ section_id }} .shopify-help-chat__messages {
    min-height: 80px;
    max-height: 320px;
    overflow-y: auto;
    padding: 8px;
  }

  #{{ section_id }} .shopify-help-chat__message {
    margin: 0 0 12px;
    line-height: 1.5;
    white-space: pre-wrap;
    word-break: break-word;
  }

  #{{ section_id }} .shopify-help-chat__message:last-child {
    margin-bottom: 0;
  }

  #{{ section_id }} .shopify-help-chat__message strong {
    display: inline-block;
    margin-bottom: 4px;
  }

  #{{ section_id }} .shopify-help-chat__message--assistant {
    color: var(--help-text);
  }

  #{{ section_id }} .shopify-help-chat__message--user {
    color: var(--help-muted);
  }

  #{{ section_id }} .shopify-help-chat__form {
    margin-top: 12px;
  }

  #{{ section_id }} .shopify-help-chat__input {
    width: 100%;
    padding: 16px 18px;
    border: 1px solid var(--help-border);
    border-radius: 10px;
    font-size: 1rem;
    outline: none;
    background: #ffffff;
    color: var(--help-text);
  }

  #{{ section_id }} .shopify-help-chat__input:focus {
    border-color: #111111;
  }

  #{{ section_id }} .shopify-help-chat__status {
    margin: 10px 0 0;
    min-height: 20px;
    color: var(--help-muted);
    font-size: 0.95rem;
  }
</style>

<script>
  (() => {
    const root = document.getElementById({{ section_id | json }});
    if (!root || root.dataset.initialized === "true") {
      return;
    }

    root.dataset.initialized = "true";

    const apiUrl = {{ api_url | json }};
    const messagesEl = root.querySelector("[data-help-messages]");
    const formEl = root.querySelector("[data-help-form]");
    const inputEl = root.querySelector("[data-help-input]");
    const statusEl = root.querySelector("[data-help-status]");
    const conversation = [];

    function renderMessage(role, text) {
      const wrapper = document.createElement("p");
      wrapper.className = "shopify-help-chat__message " + (role === "user"
        ? "shopify-help-chat__message--user"
        : "shopify-help-chat__message--assistant");

      const title = document.createElement("strong");
      title.textContent = role === "user" ? "You" : "Assistant";

      wrapper.appendChild(title);
      wrapper.appendChild(document.createElement("br"));
      wrapper.appendChild(document.createTextNode(text));

      messagesEl.appendChild(wrapper);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    async function sendConversation() {
      statusEl.textContent = "Thinking...";

      const response = await fetch(apiUrl, {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          conversation
        })
      });

      const payload = await response.json();

      if (!response.ok) {
        throw new Error(payload.error || "Something went wrong.");
      }

      return payload;
    }

    formEl.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (!apiUrl) {
        statusEl.textContent = "Add your backend API URL in the section settings.";
        return;
      }

      const text = inputEl.value.trim();
      if (!text) {
        return;
      }

      conversation.push({ role: "user", content: text });
      renderMessage("user", text);
      inputEl.value = "";
      inputEl.disabled = true;

      try {
        const payload = await sendConversation();
        const answer = payload.reply || "I couldn't find an answer yet.";

        conversation.push({ role: "assistant", content: answer });
        renderMessage("assistant", answer);
        statusEl.textContent = payload.usedTools || "";
      } catch (error) {
        renderMessage("assistant", error.message);
        statusEl.textContent = "The request did not complete.";
      } finally {
        inputEl.disabled = false;
        inputEl.focus();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Shopify Help Chat",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What are you shopping for today?"
    },
    {
      "type": "text",
      "id": "intro_message",
      "label": "Intro message",
      "default": "Ask about products, sizing, shipping, or recommendations."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Type here and press Enter"
    },
    {
      "type": "url",
      "id": "api_url",
      "label": "Backend API URL",
      "info": "Public HTTPS endpoint for your OpenAI proxy, such as https://your-backend.example.com/api/chat"
    }
  ],
  "presets": [
    {
      "name": "Shopify Help Chat"
    }
  ]
}
{% endschema %}
